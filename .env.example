NODE_ENV=development
PORT=5000
MONGO_URI=xxxx
JWT_SECRET=xxxx
JWT_EXPIRES_IN=1d
# Admin → Auto-Login (impersonation). Tokens carry an `act` claim with the
# admin's id; the handoff to the new tab uses a one-time code (not the JWT).
IMPERSONATION_TOKEN_EXPIRES_IN=1h
IMPERSONATION_CODE_TTL_SECONDS=120

# Password reset flow
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_RATE_WINDOW_MINUTES=60
PASSWORD_RESET_RATE_MAX=3

# Frontend origin(s) allowed by CORS. Single origin or comma-separated list.
# REQUIRED in production. In dev, defaults to http://localhost:8080.
# Examples:
#   CLIENT_ORIGIN=http://localhost:8080
#   CLIENT_ORIGIN=https://portal.example.com,https://staff.example.com
CLIENT_ORIGIN=http://localhost:8080

# KYC uploads (GridFS). Default 3145728 (3 MiB). Keep small on free Atlas tiers.
# KYC_MAX_FILE_BYTES=3145728

# MT5: set MT5_AUTOMATION_ENABLED=false when you provision MT5 manually (no bridge API).
# MT5_SUPPORT_EMAIL is optional: if unset, the app uses the SMTP "username" from Admin → SMTP Settings.
MT5_AUTOMATION_ENABLED=false
MT5_SUPPORT_EMAIL=

# Email content is only from Admin → Email Templates. Run: npm run seed:emailers

# Required only when MT5_AUTOMATION_ENABLED=true (default)
MT5_SERVICE_BASE_URL=http://localhost:8001
MT5_SERVICE_API_KEY=xxxx
MT5_LOGIN=xxxx
MT5_PASSWORD=xxxx
MT5_SERVER=xxxx